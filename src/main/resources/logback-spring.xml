<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_PATTERN" value="[%d{yyyy/MM/dd HH:mm:ss}] [%-5level] %msg%n" />

    <property name="LOG_DIR" value="logs/O_002_0005_DOBOTORE_log" />

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/%d{yyMMdd}_O_002_0005_DOBOTORE.log</fileNamePattern>
            <maxHistory>90</maxHistory> </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <logger name="org.springframework" level="WARN" />
    <logger name="org.apache.catalina" level="WARN" />
    <logger name="org.apache.tomcat" level="WARN" />
    <logger name="org.hibernate" level="WARN" />
    <logger name="org.springframework.boot.StartupInfoLogger" level="OFF" />
    <logger name="org.apache.coyote.http11.Http11NioProtocol" level="WARN" />
    <logger name="org.springframework.boot.autoconfigure.thymeleaf.ThymeleafAutoConfiguration" level="ERROR" />
    <logger name="org.springframework.boot.SpringApplication" level="WARN" />

    <logger name="com.example.DOBOKU1" level="INFO" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
</configuration>